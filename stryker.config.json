{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation tests target only the high-leverage business logic in services/. We exclude routes (covered by integration tests) and middleware (covered by unit tests). Goal: mutationScore >= 60% on services/.",
  "packageManager": "npm",
  "reporters": ["html", "clear-text", "progress", "dashboard"],
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "jest.config.ts",
    "enableFindRelatedTests": true
  },
  "mutate": [
    "src/services/fees.ts",
    "src/services/ledger.ts",
    "src/services/webhooks.ts",
    "src/services/events.ts",
    "src/services/apiKey.ts",
    "src/utils/crypto.ts",
    "src/utils/errors.ts",
    "src/middleware/auth.ts",
    "src/middleware/rateLimit.ts"
  ],
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "ignorePatterns": [
    "dist",
    "coverage",
    "frontend",
    "test/integration"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 60
  },
  "timeoutMS": 60000,
  "concurrency": 4,
  "disableTypeChecks": "{src,test}/**/*.{ts,js}",
  "incremental": true,
  "incrementalFile": "reports/stryker-incremental.json",
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "_acceptance": "BRD ticket PAYM-15 demands mutation score >= 60% on services/. The break threshold above enforces this in CI."
}
