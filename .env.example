# App
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database
DATABASE_URL=postgresql://payments:payments_dev@localhost:5432/payments_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT (dashboard sessions) — generate with: openssl rand -base64 64
JWT_SECRET=change_me_generate_with_openssl_rand_base64_64
JWT_EXPIRES_IN=30m

# API Keys
API_KEY_SALT_ROUNDS=2
# ^ argon2 memory cost — 2 for dev speed, bump to 4+ in prod

# Razorpay (get from dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=xxxx

# Encryption (KMS in prod, local key for dev) — generate: openssl rand -hex 32
ENCRYPTION_KEY=change_me_32_byte_hex_key_here

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100